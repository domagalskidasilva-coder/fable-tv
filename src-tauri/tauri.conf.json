{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fable TV",
  "version": "0.2.1",
  "identifier": "com.fabletv.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fable TV",
        "width": 1320,
        "height": 840,
        "minWidth": 880,
        "minHeight": 560,
        "center": true,
        "backgroundColor": "#0a0d14"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: http: data: blob:; media-src 'self' blob: https: http:; connect-src 'self' ipc: http://ipc.localhost https: http: blob:; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**", "$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
